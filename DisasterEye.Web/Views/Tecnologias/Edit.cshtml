@model DisasterEye.Web.Models.TecnologiaFormViewModel
@{
    ViewData["Title"] = "Editar Tecnologia";
}

<div class="de-page-header">
    <h2 class="de-page-title"><i class="bi bi-pencil-square"></i> Editar Tecnologia</h2>
    <a asp-action="Index" class="de-btn de-btn--ghost"><i class="bi bi-arrow-left"></i> Voltar</a>
</div>

<div class="de-panel" style="max-width:800px">
    <div class="de-panel-header"><i class="bi bi-satellite"></i> Editar Dados</div>
    <div class="de-panel-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="de-alert de-alert-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Nome" class="de-label"></label>
                    <input asp-for="Nome" class="de-input form-control" />
                    <span asp-validation-for="Nome" class="de-validation"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Descricao" class="de-label"></label>
                    <textarea asp-for="Descricao" class="de-input form-control" rows="3"></textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="OrigemEspacial" class="de-label"></label>
                    <input asp-for="OrigemEspacial" class="de-input form-control" />
                    <span asp-validation-for="OrigemEspacial" class="de-validation"></span>
                </div>
                <div class="col-md-6">
                    <label class="de-label">Categoria de Impacto</label>
                    <select asp-for="CategoriaImpactoId" class="de-input form-select"
                        asp-items="@(new SelectList(Model.Categorias, "Id", "Nome"))">
                    </select>
                    <span asp-validation-for="CategoriaImpactoId" class="de-validation"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Latitude" class="de-label"></label>
                    <input asp-for="Latitude" class="de-input form-control" type="number" step="0.000001" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Longitude" class="de-label"></label>
                    <input asp-for="Longitude" class="de-input form-control" type="number" step="0.000001" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Status" class="de-label"></label>
                    <select asp-for="Status" class="de-input form-select">
                        <option value="Ativo">Ativo</option>
                        <option value="Monitorando">Monitorando</option>
                        <option value="Alerta">Alerta</option>
                        <option value="Crítico">Crítico</option>
                    </select>
                </div>
                <div class="col-12 mt-2 d-flex gap-2">
                    <button type="submit" class="de-btn de-btn--primary">
                        <i class="bi bi-check-lg"></i> Salvar Alterações
                    </button>
                    <a asp-action="Index" class="de-btn de-btn--ghost">Cancelar</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
