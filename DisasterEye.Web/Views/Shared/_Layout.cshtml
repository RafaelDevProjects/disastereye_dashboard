<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DisasterEye</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Rajdhani:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="de-wrapper">

    <!-- Sidebar -->
    <nav class="de-sidebar" id="sidebar">
        <div class="de-sidebar-brand">
            <span class="de-satellite-icon"><i class="bi bi-broadcast"></i></span>
            <div>
                <div class="de-brand-title">DisasterEye</div>
                <div class="de-brand-sub">Space Monitoring System</div>
            </div>
        </div>

        <div class="de-sidebar-section">NAVEGAÇÃO</div>
        <ul class="de-nav">
            <li>
                <a asp-controller="Home" asp-action="Index"
                   class="de-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li>
                <a asp-controller="Tecnologias" asp-action="Index"
                   class="de-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tecnologias" ? "active" : "")">
                    <i class="bi bi-radar"></i> Tecnologias
                </a>
            </li>
        </ul>

        @if (User.FindFirst("Perfil")?.Value == "Administrador")
        {
            <div class="de-sidebar-section">ADMINISTRAÇÃO</div>
            <ul class="de-nav">
                <li>
                    <a asp-controller="Tecnologias" asp-action="Create" class="de-nav-link">
                        <i class="bi bi-plus-circle"></i> Nova Tecnologia
                    </a>
                </li>
            </ul>
        }

        <div class="de-sidebar-footer">
            <div class="de-user-info">
                <div class="de-user-avatar"><i class="bi bi-person-circle"></i></div>
                <div>
                    <div class="de-user-name">@User.Identity?.Name</div>
                    <div class="de-user-role">@User.FindFirst("Perfil")?.Value</div>
                </div>
            </div>
            <a asp-controller="Account" asp-action="Logout" class="de-logout-btn">
                <i class="bi bi-box-arrow-right"></i> Sair
            </a>
        </div>
    </nav>

    <!-- Main -->
    <main class="de-main">
        <div class="de-topbar">
            <button class="de-sidebar-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">
                <i class="bi bi-list"></i>
            </button>
            <div class="de-topbar-title">@ViewData["Title"]</div>
            <div class="de-topbar-status">
                <span class="de-pulse"></span> Sistema Online
            </div>
        </div>

        @if (TempData["Sucesso"] != null)
        {
            <div class="de-alert de-alert-success mx-4 mt-3">
                <i class="bi bi-check-circle-fill"></i> @TempData["Sucesso"]
            </div>
        }
        @if (TempData["Erro"] != null)
        {
            <div class="de-alert de-alert-danger mx-4 mt-3">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Erro"]
            </div>
        }

        <div class="de-content">
            @RenderBody()
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
